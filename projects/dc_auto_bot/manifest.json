{
  "manifest_version": 3,
  "name": "DC Auto Bot",
  "version": "1.1.0",
  "description": "신문고 게시물 댓글 명령을 기반으로 삭제 및 차단을 수행하는 운영 보조 확장",
  "permissions": [
    "storage",
    "alarms",
    "cookies",
    "identity"
  ],
  "host_permissions": [
    "https://gall.dcinside.com/*",
    "https://*.dcinside.co.kr/*",
    "https://generativelanguage.googleapis.com/*",
    "https://www.googleapis.com/*"
  ],
  "background": {
    "service_worker": "background/background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
