{
  "manifest_version": 3,
  "name": "DC IP Ban",
  "version": "1.0.0",
  "description": "디시인사이드 도배기 탭 유동 게시물 자동 차단 및 수동 해제",
  "permissions": [
    "storage",
    "alarms",
    "cookies"
  ],
  "host_permissions": [
    "https://gall.dcinside.com/*"
  ],
  "background": {
    "service_worker": "background/background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup/popup.html"
  }
}
